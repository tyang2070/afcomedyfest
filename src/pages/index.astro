---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImg from '../../assets/af_logo.png';
import { PERFORMERS } from '../data/performers';

const eventDates = 'September 3-6, 2026';

const featuredActs = PERFORMERS;

const allPerformers = PERFORMERS.sort((a, b) => a.name.localeCompare(b.name));

const sponsors = [
  { name: 'The Wall', logo: '/placeholder-sponsor.png' },
  { name: 'Solita', logo: '/placeholder-sponsor.png' },
  { name: 'Black Iris', logo: '/placeholder-sponsor.png' },
  { name: 'Ohift Creative', logo: '/placeholder-sponsor.png' },
  { name: 'Eye Care Center', logo: '/placeholder-sponsor.png' },
  { name: 'Local Business 2', logo: '/placeholder-sponsor.png' },
  { name: 'Local Business 3', logo: '/placeholder-sponsor.png' },
  { name: 'Local Business 4', logo: '/placeholder-sponsor.png' }
];
---

<Layout title="AF Comedy Fest - Home">
  <div class="homepage">
    <!-- Hero Section with Logo -->
    <section class="hero-section">
      <div class="hero-content">
        <div class="logo-container">
          <img src={logoImg.src} alt="AF Comedy Fest Logo" class="festival-logo-img" />
        </div>
      </div>
    </section>

    <!-- Dates and Location Banner -->
    <section class="dates-location-banner">
      <div class="festival-title">Asian AF Comedy Festival</div>
      <div class="dates-location-content">
        <span class="dates">{eventDates}</span>
        <span class="separator">/</span>
        <a href="https://outsideintheatre.org/" target="_blank" rel="noopener noreferrer" class="location">
          Los Angeles, CA (Outside In Theatre)
        </a>
      </div>
    </section>

    <!-- Featured Acts Section -->
    <section class="featured-acts-section">
      <div class="section-label">FEATURING FEATURING FEATURING FEATURING FEATURING FEATURING</div>
      <div class="featured-grid">
        {featuredActs.map((act) => (
          <a href={`/performers/${act.slug}`} class="featured-card-link">
            <div class="featured-card">
              <div class="featured-image">
                {act.image
                  ? <Image src={act.image} alt={act.name} width={200} height={200} />
                  : <div class="featured-image-placeholder">{act.name[0]}</div>
                }
              </div>
              <h3 class="featured-name">{act.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- All Performers Section -->
    <section class="performers-section">
      <div class="performers-content">
        <div class="performers-list">
          {allPerformers.map((performer, idx) => (
            <>
              {idx > 0 && <span class="separator-text"> / </span>}
              <a href={`/performers/${performer.slug}`} class="performer-name">{performer.name}</a>
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- Sponsors Section -->
    <section class="sponsors-section">
      <div class="section-label sponsors-label">SPONSORS SPONSORS SPONSORS SPONSORS SPONSORS SPONSORS</div>
      <div class="sponsors-grid">
        {sponsors.map((sponsor) => (
          <div class="sponsor-card">
            <div class="sponsor-logo">
              <img src={sponsor.logo} alt={sponsor.name} />
            </div>
            <p class="sponsor-name">{sponsor.name}</p>
          </div>
        ))}
      </div>
    </section>
  </div>

  <style>
    .homepage {
      width: 100%;
      background: #1a1a1a;
    }

    /* Hero Section */
    .hero-section {
      background: #000000;
      padding: 0.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 400px;
      position: relative;
      border: none;
      border-radius: 0;
      margin: 0;
      border-bottom: 2px solid #D4A574;
    }

    .hero-content {
      text-align: center;
      width: 100%;
    }

    .logo-container {
      background: #000000;
      border: none;
      border-radius: 0;
      padding: 1rem;
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .festival-logo-img {
      max-width: 100%;
      height: auto;
      max-height: 500px;
    }

    /* Dates and Location Banner */
    .dates-location-banner {
      background: #000000;
      padding: 2rem;
      text-align: center;
      color: #D4A574;
      border-top: 2px solid #D4A574;
      border-bottom: 2px solid #D4A574;
    }

    .festival-title {
      font-size: 3.5rem;
      font-weight: 700;
      color: #D4A574;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-align: center;
      margin-bottom: 1.5rem;
      font-family: 'Antonio', sans-serif;
    }

    .dates-location-content {
      font-size: 2.2rem;
      font-weight: 700;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      font-family: 'Antonio', sans-serif;
    }

    .separator {
      color: #D4A574;
      font-size: 2rem;
    }

    .location {
      color: #D4A574;
      text-decoration: none;
      transition: opacity 0.3s;
      border-bottom: 2px solid transparent;
      transition: border-bottom 0.3s;
    }

    .location:hover {
      opacity: 0.8;
      border-bottom-color: #D4A574;
    }

    /* Featured Acts Section */
    .featured-acts-section {
      background: #1a1a1a;
      padding: 4rem 4rem;
      color: white;
      width: 100%;
      border-top: 2px solid #D4A574;
      border-bottom: 2px solid #D4A574;
    }

    .section-label {
      font-size: 1.2rem;
      font-weight: 900;
      color: #D4A574;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 3rem;
      font-family: 'Antonio', sans-serif;
    }

    .featured-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
    }

    .featured-card-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .featured-card {
      text-align: center;
      transition: transform 0.3s;
    }

    .featured-card-link:hover .featured-card {
      transform: translateY(-4px);
    }

    .featured-image {
      width: 200px;
      height: 200px;
      border-radius: 20px;
      overflow: hidden;
      margin: 0 auto 1rem;
      background: #555;
    }

    .featured-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .featured-image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3rem;
      font-weight: 700;
      color: #D4A574;
      background: #2a2a2a;
    }

    .featured-name {
      font-size: 1.4rem;
      font-weight: 700;
      color: #D4A574;
      margin: 0.5rem 0;
      font-family: 'Antonio', sans-serif;
    }

    .featured-type {
      font-size: 0.9rem;
      color: #E8DCC8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0.25rem 0;
    }

    .featured-location {
      font-size: 0.85rem;
      color: #E8DCC8;
      margin: 0;
    }

    /* All Performers Section */
    .performers-section {
      background: #1a1a1a;
      padding: 4rem 4rem;
      border-top: 2px solid #D4A574;
      border-bottom: 2px solid #D4A574;
      width: 100%;
    }

    .performers-content {
      width: 100%;
    }

    .performers-list {
      text-align: center;
      font-size: 1rem;
      line-height: 1.8;
      color: #D4A574;
      font-weight: 500;
      font-family: 'Antonio', sans-serif;
      word-spacing: 0.1em;
    }

    .performer-name {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px solid #D4A574;
      display: inline;
      padding-bottom: 1px;
    }

    .performer-name:hover {
      opacity: 0.7;
    }

    .separator-text {
      color: #D4A574;
      margin: 0 0.25rem;
    }

    /* Sponsors Section */
    .sponsors-section {
      background: #1a1a1a;
      padding: 4rem 4rem;
      color: white;
      width: 100%;
      border-top: 2px solid #D4A574;
    }

    .sponsors-label {
      margin-bottom: 3rem;
    }

    .sponsors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
    }

    .sponsor-card {
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .sponsor-logo {
      width: 160px;
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(212, 165, 116, 0.1);
      border-radius: 12px;
      margin-bottom: 1rem;
      border: 1px solid #D4A574;
    }

    .sponsor-logo img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }

    .sponsor-name {
      font-size: 0.95rem;
      font-weight: 600;
      color: white;
      margin: 0;
      font-family: 'Antonio', sans-serif;
    }

    @media (max-width: 1024px) {
      .featured-acts-section {
        padding: 3rem 2rem;
      }

      .performers-section {
        padding: 3rem 2rem;
      }

      .sponsors-section {
        padding: 3rem 2rem;
      }
    }

    @media (max-width: 768px) {
      .hero-section {
        min-height: 300px;
        margin: 1rem;
        border-width: 15px;
      }

      .festival-logo {
        font-size: 2.5rem;
      }

      .dates-location-content {
        font-size: 1.5rem;
        gap: 0.75rem;
      }

      .featured-acts-section {
        padding: 2rem 1.5rem;
      }

      .featured-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .featured-image {
        width: 150px;
        height: 150px;
      }

      .featured-name {
        font-size: 1.1rem;
      }

      .performers-section {
        padding: 2rem 1.5rem;
      }

      .performers-list {
        font-size: 0.9rem;
      }

      .sponsors-section {
        padding: 2rem 1.5rem;
      }

      .sponsors-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }

      .sponsor-logo {
        width: 120px;
        height: 120px;
      }
    }

    @media (max-width: 480px) {
      .hero-section {
        min-height: 250px;
        margin: 0.5rem;
        border-width: 10px;
        padding: 2rem 1rem;
      }

      .festival-logo {
        font-size: 2rem;
      }

      .dates-location-content {
        font-size: 1.2rem;
        gap: 0.5rem;
      }

      .featured-acts-section {
        padding: 1.5rem 1rem;
      }

      .featured-grid {
        grid-template-columns: 1fr;
      }

      .section-label {
        font-size: 0.9rem;
        margin-bottom: 2rem;
      }

      .performers-section {
        padding: 1.5rem 1rem;
      }

      .performers-list {
        font-size: 0.8rem;
        line-height: 1.6;
      }

      .sponsors-section {
        padding: 1.5rem 1rem;
      }

      .sponsors-grid {
        grid-template-columns: 1fr;
      }

      .sponsor-logo {
        width: 100px;
        height: 100px;
      }
    }
  </style>
</Layout>
