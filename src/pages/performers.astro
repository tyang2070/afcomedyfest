---
import Layout from '../layouts/Layout.astro';
import { PERFORMERS } from '../data/performers';

const performers = PERFORMERS;

function getFirstParagraph(html: string): string {
  if (!html) return '';
  const match = html.match(/<p>.*?<\/p>/s);
  return match ? match[0] : '';
}
---

<Layout title="Performers - AF Comedy Fest">
  <div class="performers-wrapper">
    <h1>Our Performers</h1>
    <p>Meet the talented comedians and entertainers performing at AF Comedy Fest.</p>

    <div class="performers-grid">
    {performers.map((performer) => (
      <a href={`/performers/${performer.slug}`} class="performer-card-link">
        <div class="performer-card">
          <div class="performer-image">
            {performer.image ? (
              <img src={performer.image.src} alt={performer.name} />
            ) : (
              <div class="performer-image-placeholder">{performer.name[0]}</div>
            )}
          </div>
          <h3>{performer.name}</h3>
          <div class="performer-bio" set:html={performer.bio ? getFirstParagraph(performer.bio) : ''} />
          <div class="more-link">
            View Full Bio →
          </div>
        </div>
      </a>
    ))}
    </div>
  </div>

  <style>
    .performers-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: #1a1a1a;
    }

    h1 {
      color: #D4A574;
      margin-bottom: 0.5rem;
      font-size: 2rem;
    }

    .performers-wrapper > p {
      color: #E8DCC8;
    }

    .performers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .performer-card-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .performer-card {
      background: #2a2a2a;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s, box-shadow 0.3s;
      border: 2px solid transparent;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .performer-card-link:hover .performer-card {
      transform: translateY(-4px);
      box-shadow: 0 4px 16px rgba(212, 165, 116, 0.3);
      border-color: #D4A574;
    }

    .performer-image {
      width: 100%;
      height: 250px;
      background: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .performer-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .performer-image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
      font-weight: 700;
      color: #D4A574;
    }

    .performer-card h3 {
      padding: 1rem 1rem 0;
      color: #D4A574;
      margin: 0;
      font-size: 1.2rem;
    }

    .performer-bio {
      padding: 0.5rem 1rem;
      color: #E8DCC8;
      font-size: 0.9rem;
      line-height: 1.5;
      flex-grow: 1;
    }

    .performer-bio p {
      margin: 0;
    }

    .performer-bio strong {
      color: #D4A574;
      font-weight: 600;
    }

    .performer-bio em {
      font-style: italic;
    }

    .more-link {
      display: block;
      padding: 1rem;
      color: #D4A574;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.3s;
      text-align: center;
      border-top: 1px solid #333;
    }

    .performer-card-link:hover .more-link {
      background: rgba(212, 165, 116, 0.1);
    }
  </style>
</Layout>
