---
import Layout from '../layouts/Layout.astro';
import { PERFORMERS } from '../data/performers';

const performers = PERFORMERS;
---

<Layout title="Performers - AF Comedy Fest">
  <div class="performers-wrapper">
    <h1>Our Performers</h1>
    <p>Meet the talented comedians and entertainers performing at AF Comedy Fest.</p>

    <div class="performers-grid">
    {performers.map((performer) => (
      <a href={`/performers/${performer.slug}`} class="performer-card-link">
        <div class="performer-card">
          <div class="performer-image">
            {performer.image ? (
              <img src={performer.image.src} alt={performer.name} />
            ) : (
              <div class="performer-initial">{performer.name[0].toUpperCase()}</div>
            )}
          </div>
          <div class="performer-info">
            <h3>{performer.name}</h3>
            {performer.performer_type && (
              <span class="type-tag">{performer.performer_type}</span>
            )}
          </div>
        </div>
      </a>
    ))}
    </div>
  </div>

  <style>
    .performers-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: #1a1a1a;
    }

    h1 {
      color: #D4A574;
      margin-bottom: 0.5rem;
      font-size: 2rem;
    }

    .performers-wrapper > p {
      color: #E8DCC8;
    }

    .performers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .performer-card-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .performer-card {
      background: #2a2a2a;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s, box-shadow 0.3s;
      border: 2px solid transparent;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .performer-card-link:hover .performer-card {
      transform: translateY(-4px);
      box-shadow: 0 4px 16px rgba(212, 165, 116, 0.3);
      border-color: #D4A574;
    }

    .performer-image {
      width: 100%;
      aspect-ratio: 1;
      background: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .performer-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .performer-initial {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      font-weight: 700;
      color: #1a1a1a;
      background: #D4A574;
    }

    .performer-info {
      padding: 1rem;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .performer-card h3 {
      color: #D4A574;
      margin: 0;
      font-size: 1.2rem;
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .type-tag {
      display: inline-block;
      background: #D4A574;
      color: #000;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: capitalize;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .performer-card-link:hover .more-link {
      background: rgba(212, 165, 116, 0.1);
    }
  </style>
</Layout>
