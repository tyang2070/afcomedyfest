---
import Layout from '../layouts/Layout.astro';
import { PERFORMERS } from '../data/performers';

const performers = PERFORMERS;
const uniqueTypes = Array.from(new Set(performers.map(p => p.performer_type).filter(Boolean)));
const typeOrder = ['improv', 'stand-up', 'character'];
const performerTypes = typeOrder.filter(t => uniqueTypes.includes(t));
---

<Layout title="Performers - AF Comedy Fest">
  <div class="performers-wrapper">
    <h1>Our Performers</h1>
    <p>Meet the talented comedians and entertainers performing at AF Comedy Fest.</p>

    <div class="filter-buttons">
      <button class="filter-btn active" data-filter="all">All</button>
      {performerTypes.map((type) => (
        <button class="filter-btn" data-filter={type}>{type}</button>
      ))}
    </div>

    <div class="performers-grid" id="performers-grid">
    {performers.map((performer) => (
      <a href={`/performers/${performer.slug}`} class="performer-card-link" data-type={performer.performer_type}>
        <div class="performer-card">
          <div class="performer-image">
            {performer.image ? (
              <img src={performer.image.src} alt={performer.name} />
            ) : (
              <div class="performer-initial">{performer.name[0].toUpperCase()}</div>
            )}
          </div>
          <div class="performer-info">
            <h3>{performer.name}</h3>
            {performer.performer_type && (
              <span class="type-tag">{performer.performer_type}</span>
            )}
          </div>
        </div>
      </a>
    ))}
    </div>
  </div>

  <style>
    .performers-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: #1a1a1a;
    }

    h1 {
      color: #D4A574;
      margin-bottom: 0.5rem;
      font-size: 2rem;
    }

    .performers-wrapper > p {
      color: #E8DCC8;
      margin-bottom: 1.5rem;
    }

    .filter-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }

    .filter-btn {
      background: transparent;
      color: #D4A574;
      border: 2px solid #D4A574;
      padding: 0.5rem 1.25rem;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: capitalize;
      cursor: pointer;
      transition: all 0.3s;
    }

    .filter-btn:hover {
      background: #D4A574;
      color: #000;
    }

    .filter-btn.active {
      background: #D4A574;
      color: #000;
    }

    .performers-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .performer-card-link.hidden {
      display: none;
    }

    .performer-card-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .performer-card {
      background: #2a2a2a;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s, box-shadow 0.3s;
      border: 2px solid transparent;
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .performer-card-link:hover .performer-card {
      transform: translateY(-4px);
      box-shadow: 0 4px 16px rgba(212, 165, 116, 0.3);
      border-color: #D4A574;
    }

    .performer-image {
      width: 100%;
      aspect-ratio: 1;
      background: #1a1a1a;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .performer-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .performer-initial {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
      font-weight: 700;
      color: #1a1a1a;
      background: #D4A574;
    }

    .performer-info {
      padding: 1rem;
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
    }

    .performer-card h3 {
      color: #D4A574;
      margin: 0;
      font-size: 1.2rem;
      flex: 1;
    }

    .type-tag {
      display: inline-block;
      background: #D4A574;
      color: #000;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: capitalize;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .performer-card-link:hover .more-link {
      background: rgba(212, 165, 116, 0.1);
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const performerLinks = document.querySelectorAll('.performer-card-link');

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.dataset.filter;

          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          performerLinks.forEach(link => {
            if (filter === 'all' || link.dataset.type === filter) {
              link.classList.remove('hidden');
            } else {
              link.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
</Layout>
