---
import Layout from '../layouts/Layout.astro';
import aboutMarkdown from '../../data/about.md?raw';

// Convert markdown to HTML
function markdownToHtml(markdown: string): string {
  return markdown
    .replace(/^### (.*?)$/gm, '<h3>$1</h3>')
    .replace(/^## (.*?)$/gm, '<h2>$1</h2>')
    .replace(/^# (.*?)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .split('\n\n')
    .map(para => {
      const trimmed = para.trim();
      if (trimmed.length === 0) return '<div class="spacing"></div>';

      // If paragraph starts with a heading tag and has content after newline
      if (trimmed.match(/^<h[1-3]>/)) {
        const lines = trimmed.split('\n');
        const heading = lines[0];
        const content = lines.slice(1).join('\n').trim();

        if (content) {
          const text = content.replace(/\n/g, '<br>');
          return `${heading}\n<p>${text}</p>`;
        }
        return heading;
      }

      if (trimmed.match(/^<strong>/)) return trimmed;
      // Convert single line breaks to <br> tags
      const withLineBreaks = trimmed.replace(/\n/g, '<br>');
      return `<p>${withLineBreaks}</p>`;
    })
    .join('\n');
}

const htmlContent = markdownToHtml(aboutMarkdown);
---

<Layout title="About - AF Comedy Fest">
  <div class="about-wrapper">
    <div class="about-content" set:html={htmlContent} />

  <style>
    .about-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: #1a1a1a;
    }

    .about-content {
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      color: #D4A574;
      font-size: 2.5rem;
      margin: 0;
    }

    h2 {
      color: #D4A574;
      margin: 0;
      border-bottom: 2px solid #D4A574;
      padding-bottom: 0.5rem;
      font-size: 1.8rem;
    }

    h3 {
      color: #D4A574;
      margin: 0;
    }

    p {
      color: #E8DCC8;
      line-height: 1.8;
      margin: 0;
      font-size: 1rem;
    }

    .spacing {
      height: 1.5rem;
    }

    strong {
      color: #D4A574;
      font-weight: 600;
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }

    li {
      margin: 1rem 0;
      padding: 1rem;
      background: #2a2a2a;
      border-left: 4px solid #D4A574;
      border-radius: 4px;
      color: #E8DCC8;
      line-height: 1.6;
    }

    a {
      color: #D4A574;
      text-decoration: none;
      transition: opacity 0.3s;
    }

    a:hover {
      opacity: 0.8;
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.8rem;
      }

      h2 {
        font-size: 1.4rem;
      }

      p {
        font-size: 0.95rem;
      }
    }
  </style>
</Layout>
