---
import Layout from '../layouts/Layout.astro';
import aboutMarkdown from '../../data/about.md?raw';

// Convert markdown to HTML
function markdownToHtml(markdown: string): string {
  // First apply heading and bold replacements
  let content = markdown
    .replace(/^### (.*?)$/gm, '<h3>$1</h3>')
    .replace(/^## (.*?)$/gm, '<h2>$1</h2>')
    .replace(/^# (.*?)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

  // Split by lines to process content properly
  const lines = content.split('\n');
  const result: string[] = [];
  let i = 0;

  while (i < lines.length) {
    const line = lines[i].trim();

    // Handle blank lines - count consecutive ones
    if (line.length === 0) {
      result.push('<div class="spacing"></div>');
      i++;
      continue;
    }

    // Handle headings with optional following text
    if (line.match(/^<h[1-3]>/)) {
      const heading = line;
      let textLines: string[] = [];

      // Collect following non-empty, non-heading lines
      i++;
      while (i < lines.length) {
        const nextLine = lines[i].trim();
        if (nextLine.length === 0 || nextLine.match(/^<h[1-3]>/)) break;
        textLines.push(nextLine);
        i++;
      }

      result.push(heading);
      if (textLines.length > 0) {
        const text = textLines.join('<br>');
        result.push(`<p>${text}</p>`);
      }
      continue;
    }

    // Handle regular paragraphs
    const text = line.replace(/\n/g, '<br>');
    result.push(`<p>${text}</p>`);
    i++;
  }

  return result.join('\n');
}

const htmlContent = markdownToHtml(aboutMarkdown);
---

<Layout title="About - AF Comedy Fest">
  <div class="about-wrapper">
    <div class="about-content" set:html={htmlContent} />

  <style is:global>
    .spacing {
      display: block;
      height: 1rem;
      width: 100%;
    }
  </style>

  <style>
    .about-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      padding: 2rem;
      background: #1a1a1a;
    }

    .about-content {
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      color: #D4A574;
      font-size: 2.5rem;
      margin: 0;
    }

    h2 {
      color: #D4A574;
      margin: 0;
      border-bottom: 2px solid #D4A574;
      padding-bottom: 0.5rem;
      font-size: 1.8rem;
    }

    h3 {
      color: #D4A574;
      margin: 0;
    }

    p {
      color: #E8DCC8;
      line-height: 1.8;
      margin: 0;
      font-size: 1rem;
    }

    strong {
      color: #D4A574;
      font-weight: 600;
    }

    ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }

    li {
      margin: 1rem 0;
      padding: 1rem;
      background: #2a2a2a;
      border-left: 4px solid #D4A574;
      border-radius: 4px;
      color: #E8DCC8;
      line-height: 1.6;
    }

    a {
      color: #D4A574;
      text-decoration: none;
      transition: opacity 0.3s;
    }

    a:hover {
      opacity: 0.8;
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.8rem;
      }

      h2 {
        font-size: 1.4rem;
      }

      p {
        font-size: 0.95rem;
      }
    }
  </style>
</Layout>
