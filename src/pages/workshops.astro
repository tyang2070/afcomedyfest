---
import Layout from '../layouts/Layout.astro';
import { WORKSHOPS } from '../data/workshops';

const workshops = WORKSHOPS;
---

<Layout title="Workshops - AF Comedy Fest">
  <div class="workshops-wrapper">
    <div class="max-width">
      <h1>Workshops</h1>
      <p>Learn from industry experts at AF Comedy Fest. Sign up for workshops to master new skills and connect with the comedy community.</p>

      <div class="workshops-grid">
        {workshops.map((workshop) => (
          <div class="workshop-card">
            <div class="workshop-header">
              <div class="teacher-image">
                {workshop.image ? (
                  <img src={workshop.image} alt={workshop.teacher} />
                ) : (
                  <div class="image-placeholder">{workshop.teacher[0]}</div>
                )}
              </div>
              <div class="workshop-info">
                <h3>{workshop.title}</h3>
                <p class="teacher-name">by {workshop.teacher}</p>
              </div>
            </div>

            <div class="workshop-details">
              <div class="detail">
                <span class="label">Date:</span>
                <span>{workshop.date}</span>
              </div>
              <div class="detail">
                <span class="label">Time:</span>
                <span>{workshop.startTime} - {workshop.endTime}</span>
              </div>
              <div class="detail">
                <span class="label">Location:</span>
                <span>{workshop.location}</span>
              </div>
              <div class="detail">
                <span class="label">Cost:</span>
                <span>${workshop.cost}</span>
              </div>
              <div class="detail">
                <span class="label">Capacity:</span>
                <span>{workshop.capacity} spots</span>
              </div>
            </div>

            <div class="workshop-bio">
              {workshop.bio}
            </div>

            <a href={workshop.link} class="register-button">Register Now</a>
          </div>
        ))}
      </div>
    </div>
  </div>

  <style>
    .workshops-wrapper {
      background: #1a1a1a;
      padding: 2rem;
      min-height: 100vh;
    }

    .max-width {
      max-width: 1400px;
      margin: 0 auto;
    }

    h1 {
      color: #D4A574;
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      margin-top: 0;
    }

    .workshops-wrapper > .max-width > p {
      color: #E8DCC8;
      font-size: 1.1rem;
      margin-bottom: 2rem;
    }

    .workshops-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 2rem;
    }

    .workshop-card {
      background: #2a2a2a;
      border-radius: 8px;
      overflow: hidden;
      border: 2px solid #333;
      display: flex;
      flex-direction: column;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .workshop-card:hover {
      border-color: #D4A574;
      box-shadow: 0 4px 16px rgba(212, 165, 116, 0.2);
    }

    .workshop-header {
      display: flex;
      gap: 1rem;
      padding: 1.5rem;
      background: #1a1a1a;
      border-bottom: 2px solid #333;
    }

    .teacher-image {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: #333;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }

    .teacher-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .image-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: 700;
      color: #D4A574;
    }

    .workshop-info {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .workshop-info h3 {
      color: #D4A574;
      margin: 0;
      font-size: 1.2rem;
    }

    .teacher-name {
      color: #E8DCC8;
      margin: 0.5rem 0 0;
      font-size: 0.9rem;
    }

    .workshop-details {
      padding: 1rem 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .detail {
      display: flex;
      justify-content: space-between;
      color: #E8DCC8;
      font-size: 0.9rem;
    }

    .label {
      color: #D4A574;
      font-weight: 600;
    }

    .workshop-bio {
      padding: 1rem 1.5rem;
      color: #E8DCC8;
      line-height: 1.6;
      flex-grow: 1;
      font-size: 0.95rem;
    }

    .register-button {
      margin: 1rem;
      padding: 0.75rem 1.5rem;
      background: #D4A574;
      color: #000;
      text-decoration: none;
      border-radius: 4px;
      text-align: center;
      font-weight: 600;
      transition: opacity 0.3s;
      display: block;
    }

    .register-button:hover {
      opacity: 0.9;
    }

    @media (max-width: 768px) {
      h1 {
        font-size: 1.8rem;
      }

      .workshops-grid {
        grid-template-columns: 1fr;
      }

      .workshop-header {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .detail {
        flex-direction: column;
        gap: 0.25rem;
      }
    }
  </style>
</Layout>
